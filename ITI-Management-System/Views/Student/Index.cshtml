@using ITIEntities
@model IEnumerable<Student>
@{
    Layout = null;
}

<!DOCTYPE>
<html xmlns="http://www.w3.org/1999/xhtml">
<head>
    <title>Index</title>
    <link href="~/lib/bootstrap/dist/css/bootstrap.css" rel="stylesheet" />

</head>
<body>
    <table class="table table-bordered table-hover">
        <tr>
            <th>Student Id</th>
            <th>Name</th>
            <th>Age</th>
            <th>Deparment Name</th>
            <th>Actions</th>
        </tr>
        @if (Model == null || Model.Count() == 0)
        {
            <tr>
                <td colspan="4" class="text-center">No Data Found </td>
            </tr>
        }
        else
        {

            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.ID</td>
                    <td>@item.Name </td>
                    <td>@item.Age</td>
                    <td>@item.Department.DeptName</td>
                    <td>
                        <a asp-action="details" asp-controller="student" asp-route-id="@item.ID" class="btn btn-info">Details</a>
                        <a asp-action="Edit" asp-controller="student" asp-route-id="@item.ID" class="btn btn-danger">Edit</a>
                        <a asp-action="delete" asp-controller="student" asp-route-id="@item.ID" class="btn btn-danger">Delete</a>
                    </td>
                </tr>

            }
        }
    </table>

    <div text-center mt-4>
        <a asp-action="create" class="btn btn-primary">Create Student</a>
    </div>

</body>
</html>







@using ITI_Management_System.ViewModels
@model UpdateDegreeVM

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">

            <div class="card shadow-lg border-0 rounded-4">
                <div class="card-header bg-dark text-white text-center rounded-top-4">
                    <h4 class="mb-0">Update Student Course Degree</h4>
                </div>

                <div class="card-body p-4">

                    <form asp-action="UpdateDegree" method="post">

                        <div class="mb-3">
                            <label class="form-label fw-semibold">Student</label>
                            <select asp-for="StudentId"
                                    asp-items="Model.Students"
                                    class="form-select">
                                <option value="">-- Select Student --</option>
                            </select>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold">Course</label>
                            <select asp-for="CourseId"
                                    asp-items="Model.Courses"
                                    class="form-select">
                                <option value="">-- Select Course --</option>
                            </select>
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-semibold">Degree</label>
                            <input asp-for="Degree"
                                   type="number"
                                   class="form-control"
                                   placeholder="Enter degree (0 - 100)" />
                            <span asp-validation-for="Degree" class="text-danger small"></span>
                        </div>

                        <div class="d-grid">
                            <button type="submit"
                                    class="btn btn-dark btn-lg rounded-3">
                                Save Degree
                            </button>
                        </div>

                    </form>

                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
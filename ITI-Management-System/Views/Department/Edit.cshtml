@model ITIEntities.Models.Department

@{
    Layout = "_Layout";
    ViewData["Title"] = "Edit Deparmtent";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">

            <div class="card shadow-lg">
                <div class="card-body">

                    <h4 class="card-title text-primary mb-4">
                        Edit Deparment
                    </h4>

                    <form asp-action="Edit" method="post">
                        <!-- Department Name -->
                        <div class="mb-3">
                            <label asp-for="DeptName" class="form-label"></label>
                            <input asp-for="DeptName" class="form-control" />
                            <span asp-validation-for="DeptName" class="text-danger"></span>
                        </div>

                        <!-- Capacity -->
                        <div class="mb-3">
                            <label asp-for="Capacity" class="form-label"></label>
                            <input asp-for="Capacity" type="number" class="form-control" />
                            <span asp-validation-for="Capacity" class="text-danger"></span>
                        </div>

                        <!-- Buttons -->
                        <div class="d-grid gap-2 mt-4">
                            <button type="submit" class="btn btn-primary">
                                Edit Department
                            </button>

                            <a asp-action="Index" class="btn btn-secondary">
                                Cancel
                            </a>
                        </div>

                    </form>

                </div>
            </div>

        </div>
    </div>
</div>
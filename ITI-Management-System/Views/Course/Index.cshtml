@using ITIEntities

@model IEnumerable<Course>
    @{
        Layout = null;
    }

<!DOCTYPE >
<html xmlns="http://www.w3.org/1999/xhtml">
    <head>
        <title>Index</title>
    <link href="~/lib/bootstrap/dist/css/bootstrap.css" rel="stylesheet" />

    </head>
    <body>
        
        <table class="table table-bordered table-hover">
            <tr>
                <th>Course Id</th>
                <th>Course Name</th>
                <th>Duration</th>
                <th>Actions</th>
           </tr>
        @if (Model == null || Model.Count() == 0)
            {
                <tr> 
                    <td colspan="4" class="text-center">No Data Found </td>
                </tr>    
            }
            else { 

           @foreach (var item in Model)
            {
                <tr> 
                      <td>@item.CrsId</td>
                      <td>@item.CrsName </td>
                       <td>@item.Duration</td>
                       <td>
                            <a asp-action="CourseDetails" asp-controller="course" asp-route-id="@item.CrsId" class="btn btn-info">Details</a>
                            <a asp-action="Edit" asp-controller="course" asp-route-id="@item.CrsId" class="btn btn-danger">Edit</a>
                            <a asp-action="Delete" asp-controller="course" asp-route-id="@item.CrsId" class="btn btn-danger">Delete</a>
                        </td>
                </tr>    
            
            }
         }
        </table>
   
    <div class="text-center mt-4">
        <a asp-action="Create" class="btn btn-primary btn-lg">Create Course</a>
    </div>
</body>
</html>









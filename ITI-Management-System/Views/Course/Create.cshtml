@model ITIEntities.Models.Course

@{
    ViewData["Title"] = "Create Course";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">

            <div class="card shadow-lg">
                <div class="card-body">

                    <h4 class="card-title text-primary mb-4">
                        Create New Course
                    </h4>

                    <form asp-action="Create" method="post">

                        <!-- Course ID -->
                        <div class="mb-3">
                            <label asp-for="CrsId" class="form-label"></label>
                            <input asp-for="CrsId" class="form-control" />
                            <span asp-validation-for="CrsId" class="text-danger"></span>
                        </div>

                        <!-- Course Name -->
                        <div class="mb-3">
                            <label asp-for="CrsName" class="form-label"></label>
                            <input asp-for="CrsName" class="form-control" />
                            <span asp-validation-for="CrsName" class="text-danger"></span>
                        </div>

                        <!-- Duration -->
                        <div class="mb-3">
                            <label asp-for="Duration" class="form-label"></label>
                            <input asp-for="Duration" type="number" class="form-control" />
                            <span asp-validation-for="Duration" class="text-danger"></span>
                        </div>

                        <!-- Buttons -->
                        <div class="d-grid gap-2 mt-4">
                            <button type="submit" class="btn btn-primary">
                                Save Course
                            </button>

                            <a asp-action="Index" class="btn btn-secondary">
                                Cancel
                            </a>
                        </div>

                    </form>

                </div>
            </div>

        </div>
    </div>
</div>